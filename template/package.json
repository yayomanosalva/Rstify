{
  "name": "frontend-app",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "bun ./dist/server.js",
    "check": "biome check --write",
    "dev": "NODE_ENV=development rsbuild dev --host 0.0.0.0",
    "devx": "NODE_ENV=development rsbuild build --watch & sleep 2 && FRONTEND_PORT=9400 bun --watch ./src/server.tsx",
    "build": "RSBUILD_MINIFY=false NODE_ENV=production rsbuild build",
    "preview": "NODE_ENV=production bun ./dist/server.js",
    "clean": "rm -rf dist && mkdir -p dist/static",
    "build:prod": "bun run clean && bun run build",
    "format": "prettier --write .",
    "lint": "eslint .",
    "test:e2e": "npx playwright test",
    "test:e2e:ui": "npx playwright test --ui",
    "test:e2e:headed": "npx playwright test --headed",
    "rsx:module": "bun run src/config/module-generator.ts",
    "rsx:view": "bun run src/config/view-generator.ts"
  },
  "dependencies": {
    "@elysiajs/eden": "^1.4.5",
    "@heroicons/react": "^2.2.0",
    "@hookform/resolvers": "^5.0.1",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-menubar": "^1.1.16",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-tooltip": "^1.2.7",
    "@radix-ui/themes": "^3.3.0",
    "@tanstack/react-form": "^1.2.4",
    "@tanstack/react-query": "^5.71.1",
    "@tanstack/react-query-devtools": "^5.71.1",
    "@tanstack/react-table": "^8.21.3",
    "axios": "^1.8.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "dotenv": "^16.5.0",
    "embla-carousel-react": "^8.6.0",
    "eslint-config-prettier": "^10.1.2",
    "eslint-plugin-prettier": "^5.2.6",
    "framer-motion": "^12.6.2",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.486.0",
    "next-themes": "^0.4.6",
    "postcss": "^8.5.3",
    "react": "^19.2.1",
    "react-day-picker": "^9.13.2",
    "react-device-detect": "^2.2.3",
    "react-dom": "^19.2.1",
    "react-error-boundary": "^6.0.0",
    "react-helmet": "^6.1.0",
